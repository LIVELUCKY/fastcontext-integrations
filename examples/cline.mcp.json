{
  "mcpServers": {
    "fastcontext": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/LIVELUCKY/fastcontext-integrations",
        "fastcontext-mcp",
        "--base-url",
        "http://localhost:1234/v1",
        "--model",
        "your-model-id",
        "--api-key",
        "lm-studio"
